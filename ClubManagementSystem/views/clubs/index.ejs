<!DOCTYPE html>
<html>

<head>

    <title>Clubs</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>

<div class="container mt-5">

    <h2>Club List</h2>

    <a href="/clubs/create" class="btn btn-primary mb-3">
        Add Club
    </a>

    <table class="table table-bordered">

        <thead>

            <tr>

                <th>ID</th>

                <th>Name</th>

                <th>Description</th>

            </tr>

        </thead>

        <tbody>

            <% clubs.forEach(club => { %>

                <tr>

                    <td><%= club.id %></td>

                    <td><%= club.name %></td>

                    <td><%= club.description %></td>

                </tr>

            <% }) %>

        </tbody>

    </table>

</div>

</body>

</html>