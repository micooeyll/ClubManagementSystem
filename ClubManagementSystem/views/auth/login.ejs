<form action="/login" method="POST">

    <input
        class="form-control mb-3"
        type="email"
        name="email"
        placeholder="Email"
        required>

    <input
        class="form-control mb-3"
        type="password"
        name="password"
        placeholder="Password"
        required>

    <button class="btn btn-primary">
        Login
    </button>

</form>